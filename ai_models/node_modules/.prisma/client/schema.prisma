generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Resume {
  id                  Int       @id @default(autoincrement())
  filename            String?
  name                String?
  email               String?
  linkedin            String?
  github              String?
  skills_json         String?
  experience_json     String?
  projects_json       String?
  certifications_json String?
  cv_scores           CvScore[] // Relation field
}

model CvScore {
  id              Int      @id @default(autoincrement())
  resume_id       Int
  job_description String?
  score           Int?
  explanation     String?
  scored_at       DateTime @default(now())

  resume Resume @relation(fields: [resume_id], references: [id], onDelete: Cascade)
}
