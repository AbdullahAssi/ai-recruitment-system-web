generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candidate {
  id              String           @id @default(cuid())
  name            String
  email           String           @unique
  experience      Int
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  applications    Application[]
  candidateSkills CandidateSkill[]
  emailHistory    EmailHistory[]
  resumes         Resume[]

  @@map("candidates")
}

model Resume {
  id                  String    @id @default(cuid())
  candidateId         String
  filePath            String
  fileName            String
  extractedText       String?
  uploadDate          DateTime  @default(now())
  certifications_json String?
  email               String?
  experience_json     String?
  filename            String?
  github              String?
  linkedin            String?
  name                String?
  projects_json       String?
  skills_json         String?
  phone               String?
  education_level     String?
  experience_years    Int?
  summary             String?
  cvScores            CvScore[]
  candidate           Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("resumes")
}

model CvScore {
  id            String      @id @default(cuid())
  resumeId      String
  jobId         String?
  applicationId String?     @unique
  score         Int?
  explanation   String?
  skillsMatch   Json?       // Detailed skill matching analysis
  requirements  Json?       // Requirements analysis
  scoredAt      DateTime    @default(now())
  resume        Resume      @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  job           Job?        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("cv_scores")
}

model Job {
  id           String         @id @default(cuid())
  title        String
  description  String
  location     String?
  company      String?
  requirements String?
  isActive     Boolean        @default(true)
  postedDate   DateTime       @default(now())
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  applications Application[]
  emailHistory EmailHistory[]
  jobSkills    JobSkill[]
  cvScores     CvScore[]      // Scores for this job

  @@map("jobs")
}

model JobSkill {
  id        String   @id @default(cuid())
  jobId     String
  skillName String
  required  Boolean  @default(true)
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_skills")
}

model Application {
  id          String            @id @default(cuid())
  candidateId String
  jobId       String
  score       Float?
  status      ApplicationStatus @default(PENDING)
  appliedAt   DateTime          @default(now())
  candidate   Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  cvScore     CvScore?          // AI scoring result for this application

  @@unique([candidateId, jobId])
  @@map("applications")
}

model Skill {
  id              String           @id @default(cuid())
  skillName       String           @unique
  category        String?
  createdAt       DateTime         @default(now())
  candidateSkills CandidateSkill[]

  @@map("skills")
}

model CandidateSkill {
  candidateId String
  skillId     String
  level       SkillLevel @default(INTERMEDIATE)
  createdAt   DateTime   @default(now())
  candidate   Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  skill       Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([candidateId, skillId])
  @@map("candidate_skills")
}

model EmailTemplate {
  id           String         @id @default(cuid())
  name         String         @unique
  subject      String
  body         String
  type         EmailType
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  emailHistory EmailHistory[]

  @@map("email_templates")
}

model EmailHistory {
  id           String         @id @default(cuid())
  candidateId  String
  jobId        String?
  templateId   String?
  subject      String
  body         String
  recipient    String
  status       EmailStatus    @default(PENDING)
  sentAt       DateTime?
  errorMessage String?
  createdAt    DateTime       @default(now())
  candidate    Candidate      @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job          Job?           @relation(fields: [jobId], references: [id])
  template     EmailTemplate? @relation(fields: [templateId], references: [id])

  @@map("email_history")
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  SHORTLISTED
  REJECTED
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum EmailType {
  APPLICATION_RECEIVED
  INTERVIEW_INVITE
  APPLICATION_UNDER_REVIEW
  APPLICATION_SHORTLISTED
  APPLICATION_REJECTED
  JOB_OFFER
  FOLLOW_UP
  CUSTOM
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
}
