generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [vector]
}

// User Model for Authentication
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String    // Hashed password
  role          UserRole  @default(CANDIDATE)
  name          String
  phone         String?
  isActive      Boolean   @default(true)
  isVerified    Boolean   @default(false)
  verificationToken String?
  resetToken    String?
  resetTokenExpiry DateTime?
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  candidate     Candidate?
  hrProfile     HRProfile?

  @@index([email])
  @@map("users")
}

// HR Profile Model
model HRProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  department  String?
  position    String?
  permissions Json?    // Store specific permissions
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("hr_profiles")
}

model Candidate {
  id              String           @id @default(cuid())
  userId          String?          @unique  // Link to User for authentication
  name            String
  email           String           @unique
  experience      Int?
  phone           String?
  location        String?
  bio             String?
  linkedinUrl     String?
  githubUrl       String?
  portfolioUrl    String?
  embedding       Unsupported("vector(1536)")?  // Vector embedding for semantic matching
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  // Relations
  user            User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications    Application[]
  candidateSkills CandidateSkill[]
  emailHistory    EmailHistory[]
  resumes         Resume[]
  quizAttempts    QuizAttempt[]
  feedbackGiven   Feedback[]

  @@index([email])
  @@map("candidates")
}

model Resume {
  id                  String    @id @default(cuid())
  candidateId         String
  filePath            String
  fileName            String
  extractedText       String?
  uploadDate          DateTime  @default(now())
  certifications_json String?
  email               String?
  experience_json     String?
  filename            String?
  github              String?
  linkedin            String?
  name                String?
  projects_json       String?
  skills_json         String?
  phone               String?
  education_level     String?
  experience_years    Int?
  summary             String?
  embedding           Unsupported("vector(1536)")?  // Vector embedding for semantic matching
  cvScores            CvScore[]
  candidate           Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("resumes")
}

model CvScore {
  id            String      @id @default(cuid())
  resumeId      String
  jobId         String?
  applicationId String?     @unique
  score         Int?
  explanation   String?
  skillsMatch   Json?       // Detailed skill matching analysis
  requirements  Json?       // Requirements analysis
  scoredAt      DateTime    @default(now())
  resume        Resume      @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  job           Job?        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("cv_scores")
}

model Job {
  id           String         @id @default(cuid())
  title        String
  description  String
  location     String?
  company      String?
  requirements String?
  isActive     Boolean        @default(true)
  postedDate   DateTime       @default(now())
  embedding    Unsupported("vector(1536)")?  // Vector embedding for semantic matching
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  applications Application[]
  emailHistory EmailHistory[]
  jobSkills    JobSkill[]
  cvScores     CvScore[]      // Scores for this job
  quizzes      Quiz[]

  @@map("jobs")
}

model JobSkill {
  id        String   @id @default(cuid())
  jobId     String
  skillName String
  required  Boolean  @default(true)
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_skills")
}

model Application {
  id          String            @id @default(cuid())
  candidateId String
  jobId       String
  score       Float?
  status      ApplicationStatus @default(PENDING)
  appliedAt   DateTime          @default(now())
  candidate   Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  cvScore     CvScore?          // AI scoring result for this application
  feedback    Feedback[]        // Feedback on AI predictions for this application

  @@unique([candidateId, jobId])
  @@map("applications")
}

model Skill {
  id              String           @id @default(cuid())
  skillName       String           @unique
  category        String?
  createdAt       DateTime         @default(now())
  candidateSkills CandidateSkill[]

  @@map("skills")
}

model CandidateSkill {
  candidateId String
  skillId     String
  level       SkillLevel @default(INTERMEDIATE)
  createdAt   DateTime   @default(now())
  candidate   Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  skill       Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([candidateId, skillId])
  @@map("candidate_skills")
}

model EmailTemplate {
  id           String         @id @default(cuid())
  name         String         @unique
  subject      String
  body         String
  type         EmailType
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  emailHistory EmailHistory[]

  @@map("email_templates")
}

model EmailHistory {
  id           String         @id @default(cuid())
  candidateId  String
  jobId        String?
  templateId   String?
  subject      String
  body         String
  recipient    String
  status       EmailStatus    @default(PENDING)
  sentAt       DateTime?
  errorMessage String?
  createdAt    DateTime       @default(now())
  candidate    Candidate      @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job          Job?           @relation(fields: [jobId], references: [id])
  template     EmailTemplate? @relation(fields: [templateId], references: [id])

  @@map("email_history")
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  SHORTLISTED
  REJECTED
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum EmailType {
  APPLICATION_RECEIVED
  INTERVIEW_INVITE
  APPLICATION_UNDER_REVIEW
  APPLICATION_SHORTLISTED
  APPLICATION_REJECTED
  JOB_OFFER
  FOLLOW_UP
  CUSTOM
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
}

enum UserRole {
  CANDIDATE
  HR
  ADMIN
}

// Quiz Model for Job-specific Assessments
model Quiz {
  id          String        @id @default(cuid())
  jobId       String
  title       String
  description String?
  duration    Int?          // Duration in minutes
  passingScore Float        @default(70.0)  // Percentage required to pass
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  job         Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  questions   Question[]
  attempts    QuizAttempt[]

  @@map("quizzes")
}

// Question Model for Quiz Questions
model Question {
  id            String   @id @default(cuid())
  quizId        String
  questionText  String
  questionType  QuestionType @default(MULTIPLE_CHOICE)
  options       Json?    // Array of options for multiple choice/checkbox
  correctAnswer Json     // Correct answer(s)
  points        Int      @default(1)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("questions")
}

// QuizAttempt Model for Tracking Candidate Quiz Submissions
model QuizAttempt {
  id          String   @id @default(cuid())
  quizId      String
  candidateId String
  answers     Json     // Candidate's answers
  score       Float?   // Score achieved
  passed      Boolean  @default(false)
  startedAt   DateTime @default(now())
  completedAt DateTime?
  
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

// Feedback Model for Capturing User Corrections on AI Predictions
model Feedback {
  id              String       @id @default(cuid())
  applicationId   String
  candidateId     String
  feedbackType    FeedbackType
  aiPrediction    Json         // Original AI prediction/score
  userCorrection  Json         // User's correction/actual outcome
  notes           String?
  isUsedForTraining Boolean    @default(false)  // Flag for using in model retraining
  createdAt       DateTime     @default(now())
  
  application     Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  candidate       Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("feedback")
}

// Enums for Quiz and Feedback
enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  CODING
}

enum FeedbackType {
  SCORE_CORRECTION      // When AI score doesn't match actual evaluation
  SKILL_MATCH_CORRECTION // When skill matching is incorrect
  STATUS_CORRECTION     // When predicted outcome differs from actual
  GENERAL              // General feedback
}
