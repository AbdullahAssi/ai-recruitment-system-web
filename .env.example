# Database
DATABASE_URL="postgresql://username:password@localhost:5432/cv_jd_matcher"

# File Upload
MAX_FILE_SIZE=5242880  # 5MB
UPLOAD_DIR=uploads

# FastAPI Backend (for AI features: quiz, matching, parsing)
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000/api/v1

# Internal API key shared between Next.js and FastAPI (server-side only, never NEXT_PUBLIC_)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=your-strong-random-secret-here

# OpenAI (optional, for advanced text processing)
OPENAI_API_KEY=your_openai_api_key_here